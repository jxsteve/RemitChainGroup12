# Privy app ID (PUBLIC — safe to expose in the frontend bundle).
# Found in the Privy dashboard under Settings → API keys / App ID.
# Optional: the app falls back to the RemitChain app ID if unset.
VITE_PRIVY_APP_ID=cmqxjwsuv003i0djpjj0sil43

# NOTE: the Privy App *Secret* is server-side only. Do NOT put it here or in
# any VITE_ variable — anything prefixed VITE_ is bundled into the public app.

# ---- On-chain (RemitChain smart contract on Celo) ----
# Deployed RemitChain contract address. When set (and a valid 0x address), the
# transfer flow settles on-chain via sendMoney(); when unset the app uses the
# built-in mock so the prototype still works.
VITE_REMITCHAIN_CONTRACT=

# Use Celo MAINNET (42220) instead of the Alfajores testnet. Default: testnet.
VITE_CELO_MAINNET=false

