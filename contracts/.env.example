# Throwaway TESTNET deployer private key (0x-prefixed).
# ⚠️ Never use a mainnet key here, and never commit the real .env.
PRIVATE_KEY=

# Optional RPC overrides (defaults: Celo public Forno endpoints).
ALFAJORES_RPC=
CELO_RPC=

# Optional: wallet to receive 5,000 test USDC right after deploy
# (use your Privy embedded wallet address so you can actually send).
FUND_ADDRESS=

# Optional: deploy RemitChain against an EXISTING USDC instead of MockUSDC.
USDC_ADDRESS=
